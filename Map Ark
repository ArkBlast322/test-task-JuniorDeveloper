<!DOCTYPE html>
<html lang="en">
  <head>
  	<meta charset="utf-8">
    <title>Карта</title>
    <style>
    	#map
    	{
    		width: 100%;
    		height: 700px;
    	}
    </style>
	</head>
  <body>
  	<div id="map"></div>
  	<script>
  		function initMap()
  		{
  			var element = document.getElementById('map');
  			var options = {
  				zoom: 5,
  				center: {lat: 55.751244, lng: 37.618423}
  			};
  			var myMap = new google.maps.Map(element, options)
  		
  			var marker = new google.maps.Marker({
  				position: {lat: 55.751244, lng: 37.618423},
  				map: myMap
  			})	
  		}
  	</script>
  	<script async
    src="https://maps.googleapis.com/maps/api/js?key=AIzaSyDjiFB5CEBHi9_pSGC7xRpG6F31WOvET6Q&callback=initMap">
</script>
  </body>
</html>
